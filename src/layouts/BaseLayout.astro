---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/styles.css';

export interface Props {
  title: string;
  description?: string;
  active?: 'accueil' | 'histoire' | 'nos-eglises' | 'ministeres' | 'galerie' | 'tribus' | 'don';
  hideFooter?: boolean;
  bodyClass?: string;
  head?: string;
}

const {
  title,
  description = "Église Vases d'Honneur Chicoutimi, Assemblée Plénitude d'Amour. Partager l'amour du Christ pour changer le monde.",
  active,
  hideFooter = false,
  bodyClass = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0a4a44" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_CA" />

  <link rel="icon" type="image/png" href="/img/logo/icone-vh--150x150.png" />
  <link rel="apple-touch-icon" href="/img/logo/cropped-Sans-titre-3-1-180x180.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <slot name="head" />
</head>
<body class={bodyClass}>
  <Navbar active={active} />

  <main>
    <slot />
  </main>

  {!hideFooter && <Footer />}

  <script>
    import '../scripts/main.js';
  </script>
</body>
</html>
