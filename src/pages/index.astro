---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchLatestVideos } from '../utils/fetchYoutube.mjs';

// Build-time fetch, bake les dernières vidéos YouTube dans le HTML statique.
// Re-exécuté à chaque `npm run build`.
const videos = await fetchLatestVideos(5);
const [featured, ...rest] = videos;
---

<BaseLayout
  title="Église Vases d'Honneur Chicoutimi, Assemblée Plénitude d'Amour"
  description="Église Vases d'Honneur Chicoutimi, Assemblée Plénitude d'Amour. Cultes dimanche & mercredi, 70 Rue Racine Est, Chicoutimi."
  active="accueil"
>

  <!-- ============ HERO ============ -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-bg" aria-hidden="true">
      <img src="/img/Gallery/385744452_806068568188038_1097952417221916540_n-1536x1023.jpg" alt="" />
      <img src="/img/Gallery/pst-9-2048x1365.jpg" alt="" />
      <img src="/img/Gallery/pst-16-2048x1365.jpg" alt="" />
      <img src="/img/Gallery/IMG_0331_2278-2-scaled.bk.jpg" alt="" />
    </div>
    <div class="hero-dots" aria-hidden="true"></div>

    <div class="hero-content">
      <div class="hero-ornament" aria-hidden="true"><span class="symbol">✦</span></div>
      <span class="hero-eyebrow">Bienvenue chez vous</span>
      <h1 id="hero-title">
        Église <span class="accent">Vases d'Honneur</span><br />
        Chicoutimi
      </h1>
      <p class="hero-tagline">« Partager l'amour du Christ pour changer le monde »</p>
      <p class="hero-assembly">Assemblée Plénitude d'Amour</p>

      <div class="hero-cta">
        <a href="#horaires" class="btn btn-primary">
          Voir nos cultes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="#bienvenue" class="btn btn-ghost">Découvrir l'église</a>
      </div>
    </div>

    <a href="#bienvenue" class="hero-scroll" aria-label="Faire défiler">Défiler</a>
  </section>

  <!-- ============ BIENVENUE ============ -->
  <section class="section" id="bienvenue" aria-labelledby="bienvenue-title">
    <div class="section-inner section-narrow">
      <div class="section-header reveal">
        <span class="section-subtitle">Bienvenue</span>
        <h2 class="section-title" id="bienvenue-title">Une famille, <span class="accent">une maison</span></h2>
        <p class="section-lead">
          L'Église Vases d'Honneur de Chicoutimi, Assemblée Plénitude d'Amour,
          est un lieu où chacun trouve sa place, sa famille, et la présence vivante de Dieu.
          Ici, nous croyons que la foi se vit ensemble.
        </p>
      </div>

      <div class="pastor-block reveal" data-delay="200">
        <div class="pastor-block-photo">
          <img src="/img/pasteur_abraham/93426682_2874529792628611_8719055525259509760_n-768x768.jpeg" alt="Pasteur Abraham Andebi" />
        </div>
        <div>
          <p class="pastor-block-role">Pasteur Principal</p>
          <h3 class="pastor-block-name">Abraham Andebi</h3>
          <blockquote class="pastor-block-quote">
            « Notre maison est ouverte à tous ceux qui cherchent à rencontrer Christ,
            à grandir dans la foi, et à porter Sa lumière dans leur génération.
            Vous êtes attendus comme on attend un frère, une sœur. »
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BIENVENUE, FAMILLE SPIRITUELLE (Apôtre Mohammed) ============ -->
  <section class="welcome-family" id="famille-spirituelle" aria-labelledby="famille-title">
    <div class="welcome-inner">

      <div class="welcome-portrait reveal">
        <div class="portrait-frame">
          <img src="/img/apotre_mohamed/Pst-MOHAMMED-1.jpg" alt="Apôtre Mohammed Sanogo" loading="lazy" />
        </div>
        <div class="portrait-signature">
          <span class="sig-prefix">Apôtre</span>
          <h3 class="sig-name">Mohammed Sanogo</h3>
          <p class="sig-title">Président · Life Organisation</p>
          <p class="sig-title">Senior Pastor · Vases d'Honneur Church</p>
        </div>
      </div>

      <div class="welcome-content reveal" data-delay="200">
        <h2 id="famille-title">
          Bienvenue dans ta nouvelle
          <span class="accent">famille spirituelle</span>
        </h2>

        <p>
          L'Église <strong>Vases d'Honneur Chicoutimi</strong> est une église chrétienne
          évangélique appartenant à l'organisation <strong>Life</strong>, qui regroupe
          les églises Vases d'Honneur et le ministère <em>Messages de Vie</em>,
          présidée par l'<strong>Apôtre Mohammed Sanogo</strong>.
        </p>

        <blockquote class="welcome-mission">
          « Par Christ, nous faisons des hommes, des femmes et des jeunes
          de véritables vases d'honneur, pour la manifestation de Son règne
          à Chicoutimi. »
        </blockquote>

        <p>
          Si tu cherches un lieu où tu es toujours accueilli, où tu peux fortifier
          ta foi et commencer une nouvelle vie de paix, <strong>tu es au bon endroit.</strong>
        </p>

        <a href="/histoire" class="btn btn-primary">
          En savoir plus sur nous
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>

    </div>
  </section>

  <!-- ============ RESPONSABLES AU CANADA ============ -->
  <section class="section" id="responsables" aria-labelledby="responsables-title">
    <div class="section-inner">
      <p class="leaders-subtitle reveal" id="responsables-title">Nos responsables au Canada</p>

      <div class="leaders-grid">
        <div class="leader-card reveal">
          <div class="leader-photo">
            <img src="/img/pasteurs/1575055184_253949_300x300x1-300x300.jpeg" alt="Pasteur Jose Bro" loading="lazy" />
          </div>
          <h3>Past. Jose Bro</h3>
          <p>Pasteur principal des églises Vases d'Honneur au <strong>Canada et dans les Amériques</strong>.</p>
        </div>

        <div class="leader-card reveal" data-delay="200">
          <div class="leader-photo">
            <img src="/img/pasteurs/161684726_130669219060342_1400648081010181921_n-300x300.jpeg" alt="Pasteur Lorenzo Cavallaro" loading="lazy" />
          </div>
          <h3>Past. Lorenzo Cavallaro</h3>
          <p>Pasteur résident de l'église Vases d'Honneur à <strong>Québec</strong>.</p>
        </div>
      </div>

      <div style="text-align:center; margin-top: 3rem;" class="reveal">
        <a href="/nos-eglises" class="btn btn-ghost">
          Voir toutes nos assemblées
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ NOS MOMENTS DE CULTE ============ -->
  <section class="section" id="horaires" aria-labelledby="horaires-title">
    <div class="section-inner section-narrow">
      <div class="section-header reveal">
        <span class="section-subtitle">Nos moments de culte</span>
        <h2 class="section-title" id="horaires-title">Rejoins-<span class="accent">nous</span></h2>
        <p class="section-lead">Chaque culte est une rencontre, chaque rencontre est une promesse.</p>
      </div>

      <div class="schedule-grid reveal">
        <article class="schedule-card">
          <div class="schedule-day-header">
            <span class="schedule-icon" aria-hidden="true">🕐</span>
            <span class="schedule-day-name">Mercredi</span>
          </div>
          <p class="schedule-single">
            19h30 à 21h30
            <span class="duration">Mercredi de l'intercession</span>
          </p>
        </article>

        <article class="schedule-card featured">
          <div class="schedule-day-header">
            <span class="schedule-icon" aria-hidden="true">🕖</span>
            <span class="schedule-day-name">Dimanche</span>
            <span class="schedule-label">Culte unique</span>
          </div>
          <ul class="timeline">
            <li><span class="time">8h30</span><span class="event">✨ Temps de prière &amp; d'intercession</span></li>
            <li><span class="time">9h30</span><span class="event">✨ Culte de contemplation et de célébration</span></li>
            <li class="highlight"><span class="time">12h30</span><span class="event">🔥 Healing Time ❤️‍🔥</span></li>
            <li><span class="time">13h00</span><span class="event">🌸 Bloom Light · Coin cocktail fraternel</span></li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ MINISTÈRES PREVIEW ============ -->
  <section class="section" id="ministeres" aria-labelledby="ministeres-title">
    <div class="section-inner">
      <div class="section-header reveal">
        <span class="section-subtitle">S'engager · Grandir · Servir</span>
        <h2 class="section-title" id="ministeres-title">Nos <span class="accent">ministères</span></h2>
        <p class="section-lead">
          Chaque ministère est une porte d'entrée pour grandir dans la foi,
          servir les autres et découvrir l'appel que Dieu a placé sur ta vie.
        </p>
      </div>

      <div class="ministry-grid">
        <a href="/ministeres#bloom" class="ministry-card reveal">
          <span class="ministry-icon" aria-hidden="true">🌸</span>
          <span class="ministry-tag">Jeunesse</span>
          <h3 class="ministry-name">Bloom</h3>
          <p class="ministry-desc">Le ministère jeunesse passionné de Jésus. « Avec Christ, ta vie va s'épanouir. »</p>
          <span class="ministry-link">Découvrir Bloom</span>
        </a>

        <a href="/ministeres#leaman" class="ministry-card reveal" data-delay="100">
          <span class="ministry-icon" aria-hidden="true">👑</span>
          <span class="ministry-tag">Femmes</span>
          <h3 class="ministry-name">Leaman</h3>
          <p class="ministry-desc">Le ministère des femmes extraordinaires : prier, s'édifier, se former pour vivre des exploits avec Dieu.</p>
          <span class="ministry-link">Découvrir Leaman</span>
        </a>

        <a href="/ministeres#departments" class="ministry-card reveal" data-delay="200">
          <span class="ministry-icon" aria-hidden="true">🤝</span>
          <span class="ministry-tag">Servir</span>
          <h3 class="ministry-name">Départements</h3>
          <p class="ministry-desc">Louange, accueil, intercession, médias, enfance, jeunesse… Trouve ton équipe et mets tes dons au service du Royaume.</p>
          <span class="ministry-link">Voir les départements</span>
        </a>

        <a href="/ministeres#bapteme" class="ministry-card reveal" data-delay="300">
          <span class="ministry-icon" aria-hidden="true">💧</span>
          <span class="ministry-tag">Engagement</span>
          <h3 class="ministry-name">Baptême</h3>
          <p class="ministry-desc">Faire le pas du baptême par immersion : un témoignage public de ta nouvelle vie en Jésus-Christ.</p>
          <span class="ministry-link">Je veux être baptisé</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ GALERIE PREVIEW ============ -->
  <section class="section" id="galerie" aria-labelledby="galerie-title">
    <div class="section-inner">
      <div class="section-header reveal">
        <span class="section-subtitle">Notre vie d'assemblée</span>
        <h2 class="section-title" id="galerie-title">En <span class="accent">images</span></h2>
        <p class="section-lead">Des moments de louange, de prière, de fraternité, capturés au fil des cultes et des événements.</p>
      </div>

      <div class="gallery-grid reveal">
        <div class="gallery-item wide" data-full="/img/Gallery/pst-9-2048x1365.jpg">
          <img src="/img/Gallery/pst-9-1024x683.jpg" alt="Moment de louange" loading="lazy" />
        </div>
        <div class="gallery-item" data-full="/img/Gallery/385744452_806068568188038_1097952417221916540_n-1536x1023.jpg">
          <img src="/img/Gallery/385744452_806068568188038_1097952417221916540_n-1024x682.jpg" alt="Prédication" loading="lazy" />
        </div>
        <div class="gallery-item tall" data-full="/img/Gallery/pst-16-2048x1365.jpg">
          <img src="/img/Gallery/pst-16-1024x683.jpg" alt="Intercession" loading="lazy" />
        </div>
        <div class="gallery-item" data-full="/img/Gallery/IMG_0889_3809.jpg">
          <img src="/img/Gallery/IMG_0889_3809-768x512.bk.jpg" alt="Vie de l'église" loading="lazy" />
        </div>
        <div class="gallery-item" data-full="/img/Gallery/pst-9-scaled.jpg">
          <img src="/img/Gallery/pst-9-768x512.jpg" alt="Communion fraternelle" loading="lazy" />
        </div>
      </div>

      <div style="text-align:center; margin-top: 2.5rem;" class="reveal">
        <a href="/galerie" class="btn btn-ghost">
          Voir toute la galerie
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ ENSEIGNEMENTS YOUTUBE ============ -->
  <section class="section" id="enseignements" aria-labelledby="enseignements-title">
    <div class="section-inner">
      <div class="section-header reveal">
        <span class="section-subtitle">La parole prêchée</span>
        <h2 class="section-title" id="enseignements-title">Derniers <span class="accent">enseignements</span></h2>
        <p class="section-lead">
          Retrouve les prédications récentes du Pasteur Abraham et de nos invités,
          directement depuis notre chaîne YouTube.
        </p>
      </div>

      {featured && (
        <div class="watch-wall reveal">
          <div class="watch-featured">
            <div class="lite-youtube featured" data-yt={featured.id} tabindex="0" role="button" aria-label={`Lire la vidéo : ${featured.title}`}>
              <img src={featured.thumbnail} alt="" loading="lazy" />
              <span class="play-btn" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </span>
              <span class="watch-badge"><span class="badge-dot" aria-hidden="true"></span>Dernier direct</span>
              <div class="watch-overlay">
                <h3 class="watch-overlay-title">{featured.title}</h3>
                <p class="watch-overlay-meta">
                  {featured.views && <span>{featured.views}</span>}
                  {featured.views && featured.published && <span class="dot">·</span>}
                  {featured.published && <span>{featured.published}</span>}
                </p>
              </div>
            </div>
          </div>

          {rest.length > 0 && (
            <ul class="watch-list">
              {rest.map((v) => (
                <li>
                  <div class="lite-youtube small" data-yt={v.id} tabindex="0" role="button" aria-label={`Lire la vidéo : ${v.title}`}>
                    <img src={v.thumbnail} alt="" loading="lazy" />
                    <span class="play-btn" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    </span>
                  </div>
                  <div class="watch-list-info">
                    <h4>{v.title}</h4>
                    <p>
                      {v.views && <span>{v.views}</span>}
                      {v.views && v.published && <span class="dot">·</span>}
                      {v.published && <span>{v.published}</span>}
                    </p>
                  </div>
                </li>
              ))}
            </ul>
          )}
        </div>
      )}

      <div style="text-align:center; margin-top: 2.5rem;" class="reveal">
        <a href="https://www.youtube.com/@vasesdhonneurchicoutimi" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          Voir toute la chaîne
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ CONTACT ============ -->
  <section class="section" id="contact" aria-labelledby="contact-title">
    <div class="section-inner section-narrow">
      <div class="section-header reveal">
        <span class="section-subtitle">Nous joindre</span>
        <h2 class="section-title" id="contact-title">Venez nous <span class="accent">rencontrer</span></h2>
      </div>

      <div class="contact-grid reveal">
        <a class="contact-card"
           href="https://www.google.com/maps/search/?api=1&query=70+Rue+Racine+Est,+Chicoutimi,+QC,+G7H+1P6"
           target="_blank" rel="noopener noreferrer">
          <span class="contact-icon-wrap" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <span class="contact-label">Adresse</span>
          <span class="contact-value">70 Rue Racine Est<br />Chicoutimi, QC, G7H 1P6</span>
        </a>

        <a class="contact-card" href="tel:+14383503229">
          <span class="contact-icon-wrap" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </span>
          <span class="contact-label">Téléphone</span>
          <span class="contact-value">(438) 350-3229</span>
        </a>

        <a class="contact-card" href="mailto:contact@evhca.com">
          <span class="contact-icon-wrap" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <span class="contact-label">Courriel</span>
          <span class="contact-value">contact@evhca.com</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ SOCIAUX ============ -->
  <section class="section" id="socials" aria-labelledby="socials-title">
    <div class="section-inner section-narrow">
      <div class="section-header reveal">
        <span class="section-subtitle">Restons connectés</span>
        <h2 class="section-title" id="socials-title">Suivez-nous en <span class="accent">ligne</span></h2>
      </div>

      <nav class="socials reveal" aria-label="Réseaux sociaux">
        <a class="social-link" href="https://www.facebook.com/vasesdhonneurchicoutimi/" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          Facebook
        </a>
        <a class="social-link" href="https://www.instagram.com/vasesdhonneurchicoutimi" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          Instagram
        </a>
        <a class="social-link" href="https://www.youtube.com/@vasesdhonneurchicoutimi" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTube
        </a>
      </nav>
    </div>
  </section>

</BaseLayout>
