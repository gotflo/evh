---
import BaseLayout from '../layouts/BaseLayout.astro';

// Montants proposés (en dollars canadiens). Le 4e (100) est présélectionné.
const amounts = [5, 10, 20, 50, 100, 500];
const defaultAmount = 100;

// Désignations, regroupées comme sur l'affiche de l'église.
const designations = [
  { group: 'Offrandes & dîmes', items: ['Offrandes', 'Dîmes', 'Prémices', 'Partenaires'] },
  { group: 'Projets',           items: ['Terrain', 'Construction'] },
  { group: 'Adoration & mission', items: ["Autel d'adoration", 'Champs missionnaires'] },
];
---

<BaseLayout
  title="Faire un don, Vases d'Honneur Chicoutimi"
  description="Soutenez l'Église Vases d'Honneur Chicoutimi par vos dons : offrandes, dîmes, prémices, partenaires, terrain, construction, autel d'adoration et champs missionnaires. Montants en dollars canadiens."
  active="don"
>

  <section class="page-hero">
    <p class="breadcrumb"><a href="/index.html">Accueil</a> <span>›</span> Faire un don</p>
    <h1>Faire un <span class="accent">don</span></h1>
    <p class="page-hero-lead">
      « Que chacun donne comme il l'a résolu en son cœur, sans tristesse ni
      contrainte, car Dieu aime celui qui donne avec joie. » <span class="verse-ref">2 Corinthiens 9:7</span>
    </p>
  </section>

  <section class="section">
    <div class="section-inner donate-wrap">

      <!-- ================= FORMULAIRE (maquette) ================= -->
      <!-- NOTE : maquette visuelle, sans paiement réel. Pour activer les dons,
           remplacer ce <form> par l'embed (iframe) de la plateforme choisie. -->
      <form class="donate-card reveal" id="donate-form" novalidate>
        <div class="donate-head">
          <span class="donate-head-title">Choisir le montant</span>
          <span class="donate-head-steps" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lock"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span class="dot on"></span><span class="dot"></span><span class="dot"></span><span class="dot"></span>
          </span>
        </div>

        <div class="donate-body">
          <p class="donate-intro">Merci pour votre don. Soyez bénis.</p>

          <!-- Montants -->
          <div class="donate-amounts" role="group" aria-label="Montant du don">
            {amounts.map((a) => (
              <button type="button" class={`donate-amount ${a === defaultAmount ? 'active' : ''}`} data-amount={a}>
                {a} $
              </button>
            ))}
          </div>

          <!-- Montant personnalisé -->
          <div class="donate-custom">
            <span class="donate-custom-prefix" aria-hidden="true">$</span>
            <input type="number" min="1" step="1" inputmode="numeric"
                   id="donate-custom-input" placeholder="Montant personnalisé"
                   aria-label="Montant personnalisé en dollars canadiens" />
          </div>

          <p class="donate-currency">Tous les montants sont en dollars canadiens (CAD).</p>

          <!-- Désignation -->
          <div class="donate-field">
            <label for="donate-designation">Désignation</label>
            <select id="donate-designation" name="designation">
              {designations.map((g) => (
                <optgroup label={g.group}>
                  {g.items.map((it) => <option value={it}>{it}</option>)}
                </optgroup>
              ))}
            </select>
          </div>

          <!-- Commentaire -->
          <div class="donate-comment">
            <label class="donate-check">
              <input type="checkbox" id="donate-comment-toggle" />
              <span>Écrivez-nous un commentaire</span>
            </label>
            <textarea id="donate-comment-text" rows="3" hidden
                      placeholder="Votre message (facultatif)"
                      aria-label="Votre commentaire"></textarea>
          </div>

          <button type="submit" class="btn btn-primary donate-submit">
            Suivant
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </button>

          <!-- Avis affiché au clic sur Suivant (maquette) -->
          <div class="donate-notice" id="donate-notice" hidden role="status" aria-live="polite"></div>
        </div>
      </form>

    </div>
  </section>

</BaseLayout>
